# =============================================
# PINGORA — Firebase Environment Variables
# =============================================
# Copy this file to .env and fill in your values from the Firebase Console.
# NEVER commit .env to version control.
# These values are exposed to the browser (Vite VITE_ prefix).
# Firebase client-side keys are safe to expose — security is enforced by Firestore rules.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# FCM — Web Push (Phase 8)
VITE_FIREBASE_VAPID_KEY=
