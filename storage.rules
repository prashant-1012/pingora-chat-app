rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Chat attachments — authenticated users can read/write files in their own conversation folders
    match /chats/{conversationId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;  // 50 MB cap
    }
  }
}
