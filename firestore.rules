rules_version = '2';
// PINGORA — Firestore Security Rules
// Phase 4 development: permissive auth-gated rules.
// Tightened to production rules in Phase 10.

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
